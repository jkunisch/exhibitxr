rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && request.auth.token.tenantId == tenantId;
    }

    // Default deny for everything
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Public snap previews: anyone can read, only Admin SDK can write
    match /public/snap-previews/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Tenant-scoped models: Unauth read only if object metadata isPublished is "true"
    match /tenants/{tenantId}/models/{allPaths=**} {
      allow read: if isTenantMember(tenantId) || (resource != null && resource.metadata.get('isPublished', 'false') == "true");
      allow write: if isTenantMember(tenantId);
    }

    // Fallback for any other tenant files: strictly private
    match /tenants/{tenantId}/{allPaths=**} {
      allow read, write: if isTenantMember(tenantId);
    }
  }
}
