# ─────────────────────────────────────────────────────────────
# ExhibitXR / 3D-Snap — Environment Variables Template
# Copy this to .env.local and fill in the values.
# NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Firebase Client (public — safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (SECRET — server-side only)
# Full JSON from Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_KEY=

# AI / 3D Generation APIs
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# Comma-separated list of Meshy API keys (round-robin)
MESHY_API_KEY=
TRIPO_API_KEY=
OPENROUTER_API_KEY=

# Outreach Crawler (scripts/outreach-crawler.ts)
OUTREACH_TENANT_ID=outreach-tenant
OPENROUTER_MODEL=minimax/minimax-m2.5
OUTREACH_PUBLISH_DEFAULT=true
GROQ_API_KEY=

# Inngest (Background Jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cloudflare R2 (GLB storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Without protocol, e.g. pub-12345.r2.dev or cdn.yourdomain.com
R2_PUBLIC_DOMAIN=

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Telegram Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App URL (used for OG tags, Stripe redirects, etc.)
NEXT_PUBLIC_APP_URL=https://3d-snap.com

# TikTok Auto-Posting
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Admin bypass (comma-separated emails for unlimited credits)
ADMIN_EMAILS=
